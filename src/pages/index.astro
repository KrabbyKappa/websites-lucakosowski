---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const cylinderItems = [
  {
    reelKey: 'bizwholistic',
    name: 'Bizwholistic',
    href: 'https://bizwholistic.com/',
    image: '/assets/site-previews/bizwholistic.jpg',
    desktopReel: '/assets/site-preview-reels/bizwholistic-landscape.jpg',
    mobileReel: '/assets/site-preview-reels/bizwholistic-portrait.jpg',
    summary: 'A live Astro business website with polished brand graphics and clear service routing.',
    external: true,
  },
  {
    reelKey: 'novatrade',
    name: 'Novatrade and Lab',
    href: 'https://novatradeandlab.com/',
    image: '/assets/site-previews/novatrade-and-lab.jpg',
    desktopReel: '/assets/site-preview-reels/novatrade-landscape.jpg',
    mobileReel: '/assets/site-preview-reels/novatrade-portrait.jpg',
    summary: 'A live client website for operations, marketing, and business support.',
    external: true,
  },
  {
    reelKey: 'verde',
    name: 'Verde Lunch Club',
    href: '/demos/basic/verde-lunch-club/',
    image: '/assets/site-previews/verde-lunch-club.jpg',
    desktopReel: '/assets/site-preview-reels/verde-landscape.jpg',
    mobileReel: '/assets/site-preview-reels/verde-portrait.jpg',
    summary: 'A warm local lunch and catering page with menu, map, and visit context.',
  },
  {
    reelKey: 'mila',
    name: 'Mila Yoga Reset',
    href: '/demos/micro/mila-yoga-testimonial/',
    image: '/assets/site-previews/mila-yoga-testimonial.jpg',
    desktopReel: '/assets/site-preview-reels/mila-landscape.jpg',
    mobileReel: '/assets/site-preview-reels/mila-portrait.jpg',
    summary: 'A quiet wellness page with direct contact, session details, and testimonial trust.',
  },
];

const carouselItems = [...cylinderItems, ...cylinderItems].map((item, index) => ({
  ...item,
  orbitKey: `${item.name.toLowerCase().replaceAll(' ', '-')}-${index}`,
  copy: index >= cylinderItems.length ? 2 : 1,
}));

const approachCases = [
  {
    key: 'bizwholistic',
    name: 'Bizwholistic',
    title: 'Bizwholistic is a full brochure website.',
    summary: 'It has room to explain the firm, distinguish several services, establish a recognizable voice, publish supporting material, and guide different visitors toward the right next step.',
    screens: [
      {
        key: 'home',
        title: 'Clear opening',
        text: 'The first screen states the promise, audience, and tone without making people work.',
        image: '/assets/approach-bizwholistic/bizwholistic-home-first-fold.jpg',
        alt: 'Bizwholistic homepage opening with its brand, positioning, and introductory content.',
      },
      {
        key: 'context',
        title: 'Brand-specific voice',
        text: 'Copy sounds written for this firm, not dropped into a theme.',
        image: '/assets/approach-bizwholistic/bizwholistic-about-context.jpg',
        alt: 'Bizwholistic About page explaining the company and its perspective.',
      },
      {
        key: 'structure',
        title: 'Calm page structure',
        text: 'Offers, tools, and next steps sit in the right places so the site feels dependable.',
        image: '/assets/approach-bizwholistic/bizwholistic-offer-structure.jpg',
        alt: 'Bizwholistic services page showing its organized offer structure.',
      },
      {
        key: 'interview',
        title: 'Interview content',
        text: 'Press material gets its own polished page, with spacing and hierarchy that respect the source.',
        image: '/assets/approach-bizwholistic/bizwholistic-interview-press.jpg',
        alt: 'Bizwholistic press and interview page showing supporting credibility content.',
      },
      {
        key: 'graphics',
        title: 'Handcrafted SVGs',
        text: 'Custom globe and compass line art make the About page feel drawn for the brand.',
        image: '/assets/approach-bizwholistic/bizwholistic-about-svg-elements.jpg',
        alt: 'Bizwholistic page showing custom globe and compass illustrations.',
      },
      {
        key: 'mobile',
        title: 'Phone-ready finish',
        text: 'The same message stays sharp, readable, and composed on narrow screens.',
        image: '/assets/approach-bizwholistic/bizwholistic-home-mobile.jpg',
        alt: 'Bizwholistic mobile screenshot showing the same website direction in a narrow viewport.',
        portrait: true,
      },
    ],
  },
  {
    key: 'novatrade',
    name: 'Novatrade and Lab',
    title: 'Novatrade and Lab is a concise corporate presence.',
    summary: 'Its job is narrower: make the company identifiable online, describe what it does in plain terms, add professionalism when the business is reviewed by banks, partners, suppliers, or prospective clients, and provide a reliable contact route.',
    screens: [
      {
        key: 'identity',
        title: 'Establish who the company is.',
        text: 'The company name, proposition, brief introduction, and contact route appear immediately, creating a clear point of reference.',
        image: '/assets/approach-novatrade/novatrade-overview.jpg',
        alt: 'Novatrade and Lab homepage identifying the company and its central proposition.',
      },
      {
        key: 'scope',
        title: 'State the scope without overbuilding.',
        text: 'A compact overview explains consulting, strategy, marketing systems, and sales support without turning the site into a large publication.',
        image: '/assets/approach-novatrade/novatrade-detail-1.jpg',
        alt: 'Novatrade and Lab page showing its growth principles and service categories.',
      },
      {
        key: 'verification',
        title: 'Make the presence practical to verify and use.',
        text: 'Company details, business email, privacy information, terms, and a direct contact route make the website useful in professional conversations.',
        image: '/assets/approach-novatrade/novatrade-detail-2.jpg',
        alt: 'Novatrade and Lab page showing company details and its contact section.',
      },
      {
        key: 'mobile',
        title: 'Phone-ready presence.',
        text: 'The same concise company profile remains clear, credible, and easy to use on a phone.',
        image: '/assets/site-previews/mobile/novatrade-and-lab-mobile.jpg',
        alt: 'Novatrade and Lab mobile homepage showing its proposition and company presentation on a phone.',
        portrait: true,
      },
    ],
  },
];

---

<ServiceLayout
  title="Websites designed around your business – Luca Kosowski"
  description="Selected websites and a clear, personal process for shaping and building a website around what your business needs."
  canonicalPath="/"
  ogTitle="Websites designed around your business – Luca Kosowski"
  ogDescription="Explore selected websites and a direct process from first direction to launch."
>
  <div class="bsp-rebuild-home" data-preview-visibility>
    <a class="skip-link" href="#demos">Skip to selected websites</a>

    <header class="showcase-topbar" data-materialized-header data-floating-header aria-label="Website development navigation">
      <a href="/" class="identity">Home</a>
      <nav id="homepage-navigation" aria-label="Website development sections">
        <a href="/faq/">FAQ</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>

    <main>
      <section id="demos" class="portfolio-hero" aria-labelledby="showcase-title">
        <div class="portfolio-grid">
          <h1 id="showcase-title" data-word-rise>Your ideal website shaped around your need</h1>

          <div class="trsnparent_wheel-stage" data-trsnparent-wheel data-cylinder-autoplay="true">
            <div class="view-home" data-cylinder-view tabindex="0" aria-label="Selected website carousel. Drag horizontally or use the arrow keys to browse.">
              <div class="cylinder-wrap" data-cylinder-wrap style={`--cylinder-count: ${carouselItems.length};`}>
                {carouselItems.map((item, index) => {
                  const angle = index * (360 / carouselItems.length);
                  return (
                    <a
                      class="cylinder-item cylinder-item--finished"
                      data-cylinder-item
                      data-cylinder-status="finished"
                      data-cylinder-name={item.name}
                      data-cylinder-index={index}
                      data-cylinder-copy={item.copy}
                      data-project-key={item.orbitKey}
                      href={item.href}
                      target={item.external ? '_blank' : undefined}
                      rel={item.external ? 'noopener noreferrer' : undefined}
                      draggable="false"
                      style={`--cylinder-angle: ${angle}deg; --cylinder-image: url('${item.image}');`}
                      aria-label={`${item.name}: ${item.summary}`}
                    >
                      <div class="website-preview-reel" data-preview-reel data-reel-key={item.reelKey} aria-hidden="true">
                        <div class="website-preview-track" data-preview-track>
                          {[1, 2].map(() => (
                            <picture>
                              <source media="(max-width: 820px)" srcset={item.mobileReel} />
                              <img src={item.desktopReel} alt="" decoding="async" draggable="false" />
                            </picture>
                          ))}
                        </div>
                      </div>
                      <span class="cylinder-item__sr-meta">{item.name}: {item.summary}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="approach" class="homepage-approach" aria-labelledby="approach-title" data-active-case="bizwholistic">
        <div class="portfolio-grid">
          <div class="homepage-approach__intro">
            <h2 id="approach-title" data-scroll-words>Different businesses need different websites.</h2>
          </div>

          <div class="approach-case-switcher" role="tablist" aria-label="Compare two website approaches">
            {approachCases.map((caseStudy, index) => (
              <button
                id={`approach-tab-${caseStudy.key}`}
                type="button"
                role="tab"
                data-approach-case-select={caseStudy.key}
                aria-controls={`approach-case-${caseStudy.key}`}
                aria-selected={index === 0 ? 'true' : 'false'}
              >
                {caseStudy.name}
              </button>
            ))}
          </div>

          <div class="approach-case-panels">
            {approachCases.map((caseStudy, caseIndex) => (
              <article
                id={`approach-case-${caseStudy.key}`}
                class="approach-case approach-proof-case"
                data-approach-case={caseStudy.key}
                role="tabpanel"
                aria-labelledby={`approach-tab-${caseStudy.key}`}
                hidden={caseIndex !== 0}
              >
                <div class="approach-case__summary approach-proof-summary">
                  <h3>{caseStudy.title}</h3>
                  <p>{caseStudy.summary}</p>
                </div>

                <div
                  class="approach-object-wrap"
                  data-approach-field={caseStudy.key}
                  data-active-screen={caseStudy.screens[0].key}
                  data-screen-count={caseStudy.screens.length}
                >
                  <div class="approach-wheel-object" role="region" aria-label={`${caseStudy.name} screenshots linked to the explanation points`}>
                    <div class="approach-wheel-orbit" aria-hidden="true"></div>
                    <div class="approach-preview-stack" aria-live="polite">
                    {caseStudy.screens.map((screen, screenIndex) => (
                      <figure
                        id={`approach-shot-${caseStudy.key}-${screen.key}`}
                        class="approach-preview-plane"
                        data-approach-screen={screen.key}
                        data-active={screenIndex === 0 ? 'true' : 'false'}
                        aria-hidden={screenIndex === 0 ? 'false' : 'true'}
                      >
                        <img src={screen.image} alt={screen.alt} loading="eager" decoding="async" data-portrait={screen.portrait ? 'true' : 'false'} />
                      </figure>
                    ))}
                    </div>
                  </div>

                  <ol class="approach-callouts" aria-label={`${caseStudy.name} explanation points`}>
                    {caseStudy.screens.map((screen, screenIndex) => (
                      <li class="approach-callout-shell">
                        <button
                          id={`approach-callout-${caseStudy.key}-${screen.key}`}
                          class="approach-callout"
                          type="button"
                          data-approach-screen-select={screen.key}
                          aria-controls={`approach-shot-${caseStudy.key}-${screen.key} approach-panel-${caseStudy.key}-${screen.key}`}
                          aria-pressed={screenIndex === 0 ? 'true' : 'false'}
                          aria-expanded="false"
                        >
                          <strong>{screen.title}</strong>
                          <span>{screen.text}</span>
                        </button>
                        <div
                          id={`approach-panel-${caseStudy.key}-${screen.key}`}
                          class="approach-callout-panel"
                          data-approach-panel={screen.key}
                          data-active="false"
                          aria-hidden="true"
                          role="region"
                          aria-labelledby={`approach-callout-${caseStudy.key}-${screen.key}`}
                        >
                          <p>{screen.text}</p>
                        </div>
                      </li>
                    ))}
                  </ol>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="homepage-process" aria-labelledby="process-title">
        <div class="portfolio-grid">
          <div class="homepage-process__intro">
            <h2 id="process-title" data-scroll-words>A clear process from first idea to launch.</h2>
            <a href="/faq/">Read the practical answers <span aria-hidden="true">→</span></a>
          </div>
          <div class="homepage-process__steps">
            <article class="homepage-process__step" data-process-step>
              <h3>Start with the goal</h3>
              <p>This determines whether the right answer is a concise company presence, a detailed brochure website, or something more specialized.</p>
            </article>
            <article class="homepage-process__step" data-process-step>
              <h3>Choose a direction</h3>
              <p>I translate the brief into visible screens so typography, imagery, structure, and tone can be judged together. You respond to something concrete rather than trying to approve an abstract style description.</p>
            </article>
            <article class="homepage-process__step" data-process-step>
              <h3>First preview</h3>
              <p>The selected direction becomes a responsive website with the agreed pages, wording, media, contact routes, and technical foundations. Each page is checked as part of one system rather than assembled as an isolated template.</p>
            </article>
            <article class="homepage-process__step" data-process-step>
              <h3>Review and launch</h3>
              <p>You review the complete result before it goes live. After launch, wording, proof, imagery, or new sections can be improved when the business has a clear reason to add them.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="homepage-contact" aria-labelledby="contact-title">
        <div class="portfolio-grid">
          <h2 id="contact-title">Get in touch to discuss your future website</h2>
          <a href="/contact/">Start the conversation <span aria-hidden="true">→</span></a>
        </div>
      </section>
    </main>
  </div>

  <script>
    import {
      classifyCarouselIntent,
      decideCarouselRelease,
      sampleCarouselVelocity,
      stepCarouselSpring,
    } from '../lib/carouselPhysics.mjs';
    import {
      getHeadingRevealProgress,
      getProcessRevealTimes,
      getProcessStepProgress,
      splitSemanticSentences,
    } from '../lib/revealTiming.mjs';

    (() => {
      const stage = document.querySelector('[data-trsnparent-wheel]');
      const wrap = stage?.querySelector('[data-cylinder-wrap]');
      const view = stage?.querySelector('[data-cylinder-view]');
      if (!stage || !wrap || !view) return;

      const items = [...wrap.querySelectorAll('[data-cylinder-item]')];
      const reels = [...wrap.querySelectorAll('[data-preview-reel]')];
      const reduceMotionQuery = matchMedia('(prefers-reduced-motion: reduce)');
      const mobileReelQuery = matchMedia('(max-width: 820px)');
      const theta = 360 / items.length;
      const REEL_DURATION_MS = 36000;
      const CENTER_REEL_PLAYBACK_RATE = 1;
      const SIDE_REEL_PLAYBACK_RATE = .5;
      const REEL_FOCUS_RANGE = theta / 2;
      const DESKTOP_CARD_GAP_PX = 96;
      const RESPONSIVE_CARD_GAP_PX = 32;
      const SINE_IN = 'cubic-bezier(.47, 0, .745, .715)';
      const SINE_OUT = 'cubic-bezier(.39, .575, .565, 1)';
      const DRAG_ANGLE_PER_PIXEL = .28;
      const CLICK_SUPPRESSION_MS = 420;
      const MANUAL_AUTOPLAY_PAUSE_MS = 4000;
      const reelMotion = {
        landscape: {
          bizwholistic: [[0, 0], [2.8 / 12, -9.16], [9.2 / 12, -40.84], [1, -50]],
          novatrade: [[0, 0], [1, -50]],
          verde: [[0, 0], [2.8 / 12, -9.20], [9.2 / 12, -40.80], [1, -50]],
          mila: [[0, 0], [2.3 / 12, -7.24], [9.7 / 12, -42.76], [1, -50]],
        },
        portrait: {
          bizwholistic: [[0, 0], [1.65 / 12, -5.04], [10.35 / 12, -44.96], [1, -50]],
          novatrade: [[0, 0], [1, -50]],
          verde: [[0, 0], [4.65 / 12, -17.33], [7.35 / 12, -32.67], [1, -50]],
          mila: [[0, 0], [4.05 / 12, -14.56], [7.95 / 12, -35.44], [1, -50]],
        },
      };
      const testDuration = Number(new URLSearchParams(location.search).get('wheelTestDuration'));
      const autoplayDuration = Number.isFinite(testDuration) && testDuration >= 1000 ? testDuration : 420000;
      let carouselVisible = true;
      const state = {
        mode: 'autoplay',
        currentAngle: 0,
        targetAngle: 0,
        angularVelocity: 0,
        activeIndex: -1,
        dragMoved: false,
        pointerId: null,
        touchIntent: 'idle',
        startX: 0,
        startY: 0,
        lastX: 0,
        lastPointerTime: 0,
        distanceX: 0,
        velocityX: 0,
        dragAngle: 0,
        preGestureTargetAngle: 0,
        originAngle: 0,
        originIndex: 0,
        settleIndex: 0,
        manualPauseUntil: 0,
        suppressClickUntil: 0,
        lastTime: performance.now(),
        frame: 0,
        reelAnimations: [],
      };

      const normalize = (index) => (index % items.length + items.length) % items.length;
      const nearestIndex = (angle) => normalize(Math.round(-angle / theta));
      const nearestAngleForIndex = (index, aroundAngle = state.targetAngle) => {
        const canonical = -normalize(index) * theta;
        return canonical + Math.round((aroundAngle - canonical) / 360) * 360;
      };
      const signedAngle = (angle) => ((angle + 180) % 360 + 360) % 360 - 180;

      const updateReelPlaybackRates = () => {
        state.reelAnimations.forEach((animation, index) => {
          const distanceFromCenter = Math.abs(signedAngle(state.currentAngle + index * theta));
          const centerInfluence = Math.max(0, 1 - distanceFromCenter / REEL_FOCUS_RANGE);
          const rate = SIDE_REEL_PLAYBACK_RATE
            + (CENTER_REEL_PLAYBACK_RATE - SIDE_REEL_PLAYBACK_RATE) * centerInfluence;
          animation.updatePlaybackRate(rate);
        });
      };
      const syncPreviewMotion = () => {
        const shouldPlay = carouselVisible && !reduceMotionQuery.matches && !document.hidden;
        state.reelAnimations.forEach((animation) => shouldPlay ? animation.play() : animation.pause());
      };

      const buildPreviewMotion = () => {
        state.reelAnimations.forEach((animation) => animation.cancel());
        const orientation = mobileReelQuery.matches ? 'portrait' : 'landscape';
        state.reelAnimations = reels.map((reel) => {
          const points = reelMotion[orientation][reel.dataset.reelKey];
          const track = reel.querySelector('[data-preview-track]');
          const linearVelocity = reel.dataset.reelKey === 'novatrade';
          const keyframes = points.map(([offset, y], pointIndex) => ({
            offset,
            transform: `translate3d(0, ${y}%, 0)`,
            easing: linearVelocity ? 'linear' : pointIndex === 0 ? SINE_IN : pointIndex === points.length - 2 ? SINE_OUT : 'linear',
          }));
          return track.animate(keyframes, { duration: REEL_DURATION_MS, iterations: Infinity });
        });
        const sharedStart = document.timeline.currentTime + 100;
        state.reelAnimations.forEach((animation) => { animation.startTime = sharedStart; });
        updateReelPlaybackRates();
        syncPreviewMotion();
      };

      const setActiveIndex = (index) => {
        const next = normalize(index);
        if (next === state.activeIndex) return;
        state.activeIndex = next;
        items.forEach((item, itemIndex) => {
          const active = itemIndex === next;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-current', String(active));
          item.tabIndex = active ? 0 : -1;
        });
        stage.dataset.activeIndex = String(next);
      };

      const layoutWheel = () => {
        const width = wrap.offsetWidth;
        const cardGap = innerWidth <= 820 ? RESPONSIVE_CARD_GAP_PX : DESKTOP_CARD_GAP_PX;
        const cardWidth = width + cardGap;
        const naturalRadius = Math.round((cardWidth / 2) / Math.tan(Math.PI / items.length));
        const radius = Math.max(naturalRadius, innerWidth <= 820 ? 230 : 520);
        items.forEach((item, index) => {
          item.style.transform = `rotateY(${index * theta}deg) translateZ(${radius}px)`;
        });
      };

      const rotateToIndex = (index) => {
        const next = normalize(index);
        state.targetAngle = nearestAngleForIndex(next);
        state.settleIndex = next;
        state.angularVelocity = 0;
        state.mode = reduceMotionQuery.matches ? 'autoplay' : 'settling';
        state.manualPauseUntil = performance.now() + MANUAL_AUTOPLAY_PAUSE_MS;
        if (reduceMotionQuery.matches) state.currentAngle = state.targetAngle;
        setActiveIndex(next);
      };
      const resetPointerInteraction = (event) => {
        if (event && view.hasPointerCapture?.(event.pointerId)) view.releasePointerCapture(event.pointerId);
        state.pointerId = null;
        state.touchIntent = 'idle';
        stage.dataset.gestureIntent = 'idle';
      };
      const finishPointerInteraction = (event) => {
        if (state.mode !== 'dragging' || event.pointerId !== state.pointerId) return;
        if (state.dragMoved) {
          const decision = decideCarouselRelease({
            distanceX: state.distanceX,
            velocityX: state.velocityX,
            originIndex: state.originIndex,
            itemCount: items.length,
            theta,
            originAngle: state.originAngle,
          });
          state.suppressClickUntil = performance.now() + CLICK_SUPPRESSION_MS;
          state.targetAngle = decision.targetAngle;
          state.settleIndex = decision.targetIndex;
          state.angularVelocity = Math.max(-240, Math.min(240, state.velocityX * DRAG_ANGLE_PER_PIXEL * 1000));
          state.mode = reduceMotionQuery.matches ? 'autoplay' : 'settling';
          state.manualPauseUntil = performance.now() + MANUAL_AUTOPLAY_PAUSE_MS;
          stage.dataset.releaseAction = decision.action;
          stage.dataset.releaseDirection = String(decision.direction);
          stage.dataset.releaseImpulse = decision.impulse.toFixed(4);
          if (reduceMotionQuery.matches) {
            state.currentAngle = state.targetAngle;
            state.angularVelocity = 0;
            setActiveIndex(state.settleIndex);
          }
        } else {
          state.targetAngle = state.preGestureTargetAngle;
          state.mode = 'autoplay';
        }
        resetPointerInteraction(event);
      };
      const cancelPointerInteraction = (event) => {
        if (state.mode !== 'dragging' || event.pointerId !== state.pointerId) return;
        if (state.dragMoved) {
          state.suppressClickUntil = performance.now() + CLICK_SUPPRESSION_MS;
          state.targetAngle = state.originAngle;
          state.settleIndex = state.originIndex;
          state.angularVelocity = Math.max(-180, Math.min(180, state.velocityX * DRAG_ANGLE_PER_PIXEL * 1000));
          state.mode = reduceMotionQuery.matches ? 'autoplay' : 'settling';
          state.manualPauseUntil = performance.now() + MANUAL_AUTOPLAY_PAUSE_MS;
          if (reduceMotionQuery.matches) state.currentAngle = state.targetAngle;
        } else {
          state.targetAngle = state.preGestureTargetAngle;
          state.mode = 'autoplay';
        }
        resetPointerInteraction(event);
      };
      const pointerMove = (event) => {
        if (state.mode !== 'dragging' || event.pointerId !== state.pointerId) return;
        const deltaX = event.clientX - state.startX;
        const deltaY = event.clientY - state.startY;
        if (event.pointerType === 'touch' && state.touchIntent === 'pending') {
          state.touchIntent = classifyCarouselIntent({
            deltaX,
            deltaY,
            currentIntent: state.touchIntent,
          });
          stage.dataset.gestureIntent = state.touchIntent;
          if (state.touchIntent === 'vertical') {
            cancelPointerInteraction(event);
            return;
          }
          if (state.touchIntent === 'pending') return;
        }
        if (Math.abs(deltaX) < 2 && !state.dragMoved) return;
        event.preventDefault();
        if (!state.dragMoved) {
          state.dragMoved = true;
          view.setPointerCapture?.(event.pointerId);
        }
        state.velocityX = sampleCarouselVelocity({
          previousX: state.lastX,
          previousTime: state.lastPointerTime,
          currentX: event.clientX,
          currentTime: event.timeStamp,
          previousVelocity: state.velocityX,
        });
        state.lastX = event.clientX;
        state.lastPointerTime = event.timeStamp;
        state.distanceX = deltaX;
        state.targetAngle = state.dragAngle + deltaX * DRAG_ANGLE_PER_PIXEL;
        state.currentAngle = state.targetAngle;
        wrap.style.transform = `rotateY(${state.currentAngle}deg)`;
        setActiveIndex(nearestIndex(state.currentAngle));
        updateReelPlaybackRates();
      };

      const tick = (now) => {
        const delta = Math.min(64, now - state.lastTime);
        state.lastTime = now;
        if (state.mode === 'settling') {
          const next = stepCarouselSpring({
            currentAngle: state.currentAngle,
            targetAngle: state.targetAngle,
            angularVelocity: state.angularVelocity,
            deltaMs: delta,
          });
          state.currentAngle = next.currentAngle;
          state.angularVelocity = next.angularVelocity;
          if (next.settled) {
            state.mode = 'autoplay';
            setActiveIndex(state.settleIndex);
          }
        } else if (state.mode !== 'dragging') {
          const paused = reduceMotionQuery.matches || document.hidden || now < state.manualPauseUntil;
          if (!paused) state.targetAngle -= delta * (360 / autoplayDuration);
          const damping = 1 - Math.exp(-delta / 130);
          state.currentAngle += (state.targetAngle - state.currentAngle) * damping;
        }
        wrap.style.transform = `rotateY(${state.currentAngle}deg)`;
        setActiveIndex(nearestIndex(state.currentAngle));
        updateReelPlaybackRates();
        stage.dataset.currentAngle = state.currentAngle.toFixed(4);
        stage.dataset.targetAngle = state.targetAngle.toFixed(4);
        stage.dataset.motionMode = state.mode;
        stage.dataset.angularVelocity = state.angularVelocity.toFixed(4);
        state.frame = requestAnimationFrame(tick);
      };

      view.addEventListener('pointerdown', (event) => {
        if (event.button !== 0) return;
        state.mode = 'dragging';
        state.angularVelocity = 0;
        state.dragMoved = false;
        state.pointerId = event.pointerId;
        state.touchIntent = event.pointerType === 'touch' ? 'pending' : 'horizontal';
        state.startX = event.clientX;
        state.startY = event.clientY;
        state.lastX = event.clientX;
        state.lastPointerTime = event.timeStamp;
        state.distanceX = 0;
        state.velocityX = 0;
        state.dragAngle = state.currentAngle;
        state.preGestureTargetAngle = state.targetAngle;
        state.originIndex = nearestIndex(state.currentAngle);
        state.originAngle = nearestAngleForIndex(state.originIndex, state.currentAngle);
        state.settleIndex = state.originIndex;
        stage.dataset.gestureIntent = state.touchIntent;
      });
      addEventListener('pointermove', pointerMove, { passive: false });
      addEventListener('pointerup', finishPointerInteraction);
      addEventListener('pointercancel', cancelPointerInteraction);
      stage.addEventListener('click', (event) => {
        const link = event.target.closest?.('a[data-cylinder-item]');
        if ((link && !link.classList.contains('is-active')) || performance.now() < state.suppressClickUntil) {
          event.preventDefault();
          event.stopPropagation();
        }
      }, true);
      stage.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        event.preventDefault();
        rotateToIndex(state.activeIndex + (event.key === 'ArrowRight' ? 1 : -1));
      });

      const observer = new IntersectionObserver(([entry]) => {
        carouselVisible = entry.isIntersecting;
        syncPreviewMotion();
      }, { threshold: 0.2 });
      observer.observe(view);
      const visibility = () => syncPreviewMotion();
      const motionChange = () => syncPreviewMotion();
      reduceMotionQuery.addEventListener?.('change', motionChange);
      mobileReelQuery.addEventListener?.('change', buildPreviewMotion);
      document.addEventListener('visibilitychange', visibility);
      const resizeObserver = new ResizeObserver(layoutWheel);
      resizeObserver.observe(view);
      resizeObserver.observe(wrap);
      addEventListener('resize', layoutWheel, { passive: true });
      addEventListener('pagehide', () => {
        cancelAnimationFrame(state.frame);
        observer.disconnect();
        resizeObserver.disconnect();
        reduceMotionQuery.removeEventListener?.('change', motionChange);
        mobileReelQuery.removeEventListener?.('change', buildPreviewMotion);
        state.reelAnimations.forEach((animation) => animation.cancel());
      }, { once: true });

      layoutWheel();
      buildPreviewMotion();
      setActiveIndex(0);
      state.frame = requestAnimationFrame(tick);
    })();

    (() => {
      const reduceMotionQuery = matchMedia('(prefers-reduced-motion: reduce)');

      const header = document.querySelector('[data-materialized-header]:not([data-floating-header])');
      const hero = document.querySelector('.portfolio-hero');
      if (header && hero) {
        const approach = document.querySelector('.homepage-approach');
        const process = document.querySelector('.homepage-process');
        const contact = document.querySelector('.homepage-contact');
        const page = document.querySelector('.bsp-rebuild-home');
        const REVEAL_WINDOW = 120;
        const INERT_THRESHOLD = .5;
        let headerFrame = 0;
        const updateHeader = () => {
          headerFrame = 0;
          const heroBottom = hero.getBoundingClientRect().bottom;
          const rawProgress = reduceMotionQuery.matches
            ? (heroBottom <= 0 ? 1 : 0)
            : (REVEAL_WINDOW - heroBottom) / REVEAL_WINDOW;
          const progress = Math.min(1, Math.max(0, rawProgress));
          header.style.setProperty('--header-progress', String(progress));
          header.toggleAttribute('inert', progress < INERT_THRESHOLD);
          const headerLine = header.getBoundingClientRect().height / 2;
          const approachBounds = approach?.getBoundingClientRect();
          const processBounds = process?.getBoundingClientRect();
          const contactBounds = contact?.getBoundingClientRect();
          const overDarkApproach = approach?.dataset.activeCase === 'novatrade'
            && approachBounds.top <= headerLine && approachBounds.bottom >= headerLine;
          const overContact = contactBounds?.top <= headerLine && contactBounds.bottom >= headerLine;
          const overDarkProcess = page?.dataset.activeCase === 'novatrade'
            && processBounds?.top <= headerLine && processBounds.bottom >= headerLine;
          header.dataset.onDark = String(overDarkApproach || overDarkProcess || overContact);
        };
        const scheduleHeaderUpdate = () => {
          if (!headerFrame) headerFrame = requestAnimationFrame(updateHeader);
        };
        addEventListener('scroll', scheduleHeaderUpdate, { passive: true });
        addEventListener('resize', scheduleHeaderUpdate, { passive: true });
        addEventListener('approachcasechange', scheduleHeaderUpdate);
        reduceMotionQuery.addEventListener?.('change', scheduleHeaderUpdate);
        updateHeader();
        addEventListener('pagehide', () => {
          cancelAnimationFrame(headerFrame);
          removeEventListener('scroll', scheduleHeaderUpdate);
          removeEventListener('resize', scheduleHeaderUpdate);
          removeEventListener('approachcasechange', scheduleHeaderUpdate);
          reduceMotionQuery.removeEventListener?.('change', scheduleHeaderUpdate);
        }, { once: true });
      }

      const splitText = (element, withCharacters) => {
        const label = element.textContent.trim();
        const fragment = document.createDocumentFragment();
        const targets = [];
        element.setAttribute('aria-label', label);
        label.split(/(\s+)/).forEach((part) => {
          if (/^\s+$/.test(part)) {
            fragment.append(part);
            return;
          }
          const word = document.createElement('span');
          word.className = withCharacters ? 'scroll-word' : 'word-rise-clip';
          word.setAttribute('aria-hidden', 'true');
          if (withCharacters) {
            [...part].forEach((character) => {
              const span = document.createElement('span');
              span.className = 'scroll-character';
              span.textContent = character;
              word.append(span);
              targets.push(span);
            });
          } else {
            const inner = document.createElement('span');
            inner.className = 'word-rise-inner';
            inner.textContent = part;
            word.append(inner);
            targets.push(inner);
          }
          fragment.append(word);
        });
        element.replaceChildren(fragment);
        return targets;
      };

      const heading = document.querySelector('[data-word-rise]');
      if (heading) {
        const words = splitText(heading, false);
        heading.dataset.wordRiseReady = 'true';
        words.forEach((word, index) => {
          const animation = word.animate([
            { opacity: 0, transform: 'translate3d(0, 115%, 0)', filter: 'blur(5px)' },
            { opacity: 1, transform: 'translate3d(0, 0, 0)', filter: 'blur(0)' },
          ], {
            duration: reduceMotionQuery.matches ? 1 : 900,
            delay: reduceMotionQuery.matches ? 0 : 100 + index * 65,
            easing: 'cubic-bezier(.22, 1, .36, 1)',
            fill: 'both',
          });
          if (reduceMotionQuery.matches) animation.finish();
        });
      }

      const responsiveRevealQuery = matchMedia('(max-width: 820px)');
      const revealGroups = [...document.querySelectorAll('[data-scroll-words]')].map((element) => {
        const characters = splitText(element, true);
        const groupDelay = Number(element.dataset.scrollDelay || 0);
        const animations = characters.map((character, index) => {
          const animation = character.animate([
            { opacity: 0, filter: 'blur(20px)' },
            { opacity: 1, filter: 'blur(0)' },
          ], {
            duration: 700,
            delay: groupDelay + index * 28,
            easing: 'cubic-bezier(.22, 1, .36, 1)',
            fill: 'both',
          });
          animation.pause();
          return animation;
        });
        return { element, animations, duration: 700 + groupDelay + Math.max(0, characters.length - 1) * 28 };
      });

      const processSection = document.querySelector('.homepage-process');
      const processSteps = [...processSection.querySelectorAll('[data-process-step]')];
      const PROCESS_REVEAL_DURATION_MS = 650;
      const splitProcessParagraph = (paragraph) => {
        const label = paragraph.textContent.trim();
        const sentences = splitSemanticSentences(label);
        const fragment = document.createDocumentFragment();
        paragraph.setAttribute('aria-label', label);
        sentences.forEach((sentence, index) => {
          const span = document.createElement('span');
          span.className = 'process-sentence';
          span.setAttribute('aria-hidden', 'true');
          span.textContent = `${sentence}${index < sentences.length - 1 ? ' ' : ''}`;
          fragment.append(span);
        });
        paragraph.replaceChildren(fragment);
        return [...paragraph.querySelectorAll('.process-sentence')];
      };
      const processAnimations = processSteps.map((step) => {
        const headingKeyframes = [
          { opacity: 0, transform: 'translate3d(0, 18px, 0)' },
          { opacity: 1, transform: 'translate3d(0, 0, 0)' },
        ];
        const heading = step.querySelector('h3').animate(headingKeyframes, {
          duration: PROCESS_REVEAL_DURATION_MS,
          easing: 'cubic-bezier(.22, 1, .36, 1)',
          fill: 'both',
        });
        heading.pause();
        const sentences = splitProcessParagraph(step.querySelector('p')).map((sentence) => {
          const animation = sentence.animate([
            { opacity: 0, filter: 'blur(7px)' },
            { opacity: 1, filter: 'blur(0)' },
          ], {
            duration: PROCESS_REVEAL_DURATION_MS,
            easing: 'cubic-bezier(.22, 1, .36, 1)',
            fill: 'both',
          });
          animation.pause();
          return animation;
        });
        return { step, heading, sentences };
      });

      let revealFrame = 0;
      const updateReveals = () => {
        revealFrame = 0;
        revealGroups.forEach(({ element, animations, duration }) => {
          const bounds = element.getBoundingClientRect();
          const progress = getHeadingRevealProgress({
            top: bounds.top,
            height: bounds.height,
            viewportHeight: innerHeight,
            isMobile: responsiveRevealQuery.matches,
            reducedMotion: reduceMotionQuery.matches,
          });
          element.dataset.revealProgress = progress.toFixed(4);
          animations.forEach((animation) => { animation.currentTime = progress * duration; });
        });
        let combinedProcessProgress = 0;
        processAnimations.forEach(({ step, heading, sentences }, stepIndex) => {
          const stepProgress = getProcessStepProgress({
            top: step.getBoundingClientRect().top,
            viewportHeight: innerHeight,
            isMobile: responsiveRevealQuery.matches,
            stepIndex,
            reducedMotion: reduceMotionQuery.matches,
          });
          const revealTimes = getProcessRevealTimes({
            progress: stepProgress,
            sentenceCount: sentences.length,
          });
          step.dataset.revealProgress = stepProgress.toFixed(4);
          heading.currentTime = revealTimes.headingTime;
          sentences.forEach((animation, sentenceIndex) => {
            animation.currentTime = revealTimes.sentenceTimes[sentenceIndex];
          });
          combinedProcessProgress += stepProgress;
        });
        processSection.dataset.processProgress = (combinedProcessProgress / Math.max(1, processAnimations.length)).toFixed(4);
      };
      const scheduleRevealUpdate = () => {
        if (!revealFrame) revealFrame = requestAnimationFrame(updateReveals);
      };
      addEventListener('scroll', scheduleRevealUpdate, { passive: true });
      addEventListener('resize', scheduleRevealUpdate, { passive: true });
      reduceMotionQuery.addEventListener?.('change', scheduleRevealUpdate);
      responsiveRevealQuery.addEventListener?.('change', scheduleRevealUpdate);
      updateReveals();
      addEventListener('pagehide', () => {
        cancelAnimationFrame(revealFrame);
        removeEventListener('scroll', scheduleRevealUpdate);
        removeEventListener('resize', scheduleRevealUpdate);
        reduceMotionQuery.removeEventListener?.('change', scheduleRevealUpdate);
        responsiveRevealQuery.removeEventListener?.('change', scheduleRevealUpdate);
      }, { once: true });
    })();

    (() => {
      const section = document.querySelector('.homepage-approach');
      if (!section) return;
      const page = section.closest('.bsp-rebuild-home');

      const tabs = [...section.querySelectorAll('[data-approach-case-select]')];
      const panels = [...section.querySelectorAll('[data-approach-case]')];
      const mobileQuery = matchMedia('(max-width: 700px)');

      const setExpanded = (field, key = '') => {
        const buttons = [...field.querySelectorAll('[data-approach-screen-select]')];
        const panels = [...field.querySelectorAll('[data-approach-panel]')];
        field.dataset.expandedScreen = key;
        buttons.forEach((button) => button.setAttribute('aria-expanded', String(button.dataset.approachScreenSelect === key)));
        panels.forEach((panel) => {
          const active = panel.dataset.approachPanel === key;
          panel.dataset.active = String(active);
          panel.setAttribute('aria-hidden', String(!active));
        });
      };

      const setScreen = (field, key) => {
        const buttons = [...field.querySelectorAll('[data-approach-screen-select]')];
        const screens = [...field.querySelectorAll('[data-approach-screen]')];
        field.dataset.activeScreen = key;
        buttons.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.approachScreenSelect === key)));
        screens.forEach((screen) => {
          const active = screen.dataset.approachScreen === key;
          screen.dataset.active = String(active);
          screen.setAttribute('aria-hidden', String(!active));
        });
      };

      section.querySelectorAll('[data-approach-field]').forEach((field) => {
        const buttons = [...field.querySelectorAll('[data-approach-screen-select]')];
        buttons.forEach((button) => {
          const key = button.dataset.approachScreenSelect;
          const activate = () => setScreen(field, key);
          button.addEventListener('pointerenter', () => { if (!mobileQuery.matches) activate(); }, { passive: true });
          button.addEventListener('focus', activate);
          button.addEventListener('click', () => {
            activate();
            if (mobileQuery.matches) setExpanded(field, field.dataset.expandedScreen === key ? '' : key);
          });
        });
        setScreen(field, buttons[0]?.dataset.approachScreenSelect);
        setExpanded(field);
      });

      const setCase = (key, focus = false) => {
        section.dataset.activeCase = key;
        page.dataset.activeCase = key;
        dispatchEvent(new Event('approachcasechange'));
        tabs.forEach((tab) => {
          const active = tab.dataset.approachCaseSelect === key;
          tab.setAttribute('aria-selected', String(active));
          tab.tabIndex = active ? 0 : -1;
          if (active && focus) tab.focus();
        });
        panels.forEach((panel) => { panel.hidden = panel.dataset.approachCase !== key; });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => setCase(tab.dataset.approachCaseSelect));
        tab.addEventListener('keydown', (event) => {
          if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
          event.preventDefault();
          const direction = event.key === 'ArrowRight' ? 1 : -1;
          const next = (index + direction + tabs.length) % tabs.length;
          setCase(tabs[next].dataset.approachCaseSelect, true);
        });
      });

      setCase(tabs[0]?.dataset.approachCaseSelect);
    })();
  </script>
</ServiceLayout>
