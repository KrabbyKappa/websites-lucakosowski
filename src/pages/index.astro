---
import { Image } from 'astro:assets';
import ServiceLayout from '../layouts/ServiceLayout.astro';
import { serviceFaq } from '../data/seo/serviceFaq';

const cylinderItems = [
  {
    name: 'Bizwholistic',
    status: 'finished',
    href: 'https://bizwholistic.com/',
    image: '/assets/site-previews/bizwholistic.jpg',
    mobileImage: '/assets/site-previews/mobile/bizwholistic-mobile-v2.jpg',
    summary: 'A live Astro business website with polished brand graphics and clear service routing.',
    external: true,
  },
  {
    name: 'Verde Lunch Club',
    status: 'finished',
    href: '/demos/basic/verde-lunch-club/',
    image: '/assets/site-previews/verde-lunch-club.jpg',
    mobileImage: '/assets/site-previews/mobile/verde-lunch-club-mobile.jpg',
    summary: 'A warm local lunch and catering page with menu, map, and visit context.',
  },
  {
    name: 'Mila Yoga Reset',
    status: 'finished',
    href: '/demos/micro/mila-yoga-testimonial/',
    image: '/assets/site-previews/mila-yoga-testimonial.jpg',
    mobileImage: '/assets/site-previews/mobile/mila-yoga-testimonial-mobile.jpg',
    summary: 'A quiet wellness micro page with direct contact, session details, and testimonial trust.',
  },
  {
    name: 'Mosaic Content Studio',
    status: 'in-progress',
    image: '/assets/site-previews/mosaic-content-studio.jpg',
    mobileImage: '/assets/site-previews/mobile/mosaic-content-studio-mobile.jpg',
    summary: 'Expressive content-studio direction being shaped into a finished example.',
  },
  {
    name: 'Harbor Legal Translation',
    status: 'in-progress',
    image: '/assets/site-previews/harbor-legal-translation.jpg',
    mobileImage: '/assets/site-previews/mobile/harbor-legal-translation-mobile.jpg',
    summary: 'Professional-service intake direction with trust and scope clarity under review.',
  },
  {
    name: 'City Lab Pop-Up',
    status: 'in-progress',
    image: '/assets/site-previews/city-lab-pop-up.jpg',
    mobileImage: '/assets/site-previews/mobile/city-lab-pop-up-mobile.jpg',
    summary: 'Bright event-poster direction being refined before opening as a demo.',
  },
];

---
<ServiceLayout title="Your Ideal Website – Luca Kosowski" description="A premium showcase of live case-study context and selected showcase sites for Luca Kosowski's Website Development portfolio." canonicalPath="/" ogTitle="Your Ideal Website – Luca Kosowski" ogDescription="Explore a live business case study, polished visual previews, and complete showcase routes for different website directions." faqItems={serviceFaq}>
  <div class="lava-lamp-bg" data-lava-lamp-bg aria-hidden="true">
    <canvas class="lava-lamp-canvas" data-lava-canvas></canvas>
  </div>

<a class="skip-link" href="#service-faq">Skip to common questions</a>

  <header class="showcase-topbar" data-materialized-header aria-label="Website development navigation">
    <a href="https://lucakosowski.com/" class="identity">Luca Kosowski</a>
    <nav aria-label="Website development sections">
      <a href="#service-faq">FAQ</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <section id="demos" class="hero hero--trsnparent_wheel" aria-labelledby="showcase-title">
      <div class="hero-layout hero-layout--trsnparent_wheel">
        <div class="hero-copy">
          <h1 id="showcase-title">Your ideal website, shaped around your need</h1>
        </div>

        <div class="trsnparent_wheel-stage" data-trsnparent-wheel data-cylinder-autoplay="true">
          <p class="carousel-drag-hint" data-carousel-drag-hint>click and drag to move</p>
          <div class="view-home" data-cylinder-view tabindex="0" aria-label="Website demo wheel">
            <div class="cylinder-wrap" data-cylinder-wrap style={`--cylinder-count: ${cylinderItems.length};`}>
              {cylinderItems.map((item, index) => {
                const angle = index * (360 / cylinderItems.length);
                const isFinished = item.status === 'finished';
                const content = (
                  <>
                    <picture>
                      <source media="(max-width: 720px)" srcset={item.mobileImage} width="390" height="844" />
                      <Image src={item.image} width={1440} height={980} alt={isFinished ? `${item.name} website preview` : ''} loading="eager" decoding="async" fetchpriority={index < 3 ? 'high' : 'auto'} draggable="false" aria-hidden={isFinished ? undefined : 'true'} />
                    </picture>
                    <span class="cylinder-item__shade" aria-hidden="true"></span>
                    <span class="cylinder-item__sr-meta">{item.name}: {item.summary}</span>
                    {isFinished ? <span class="cylinder-open-affordance" aria-hidden="true">{item.external ? 'Open website' : 'Open preview'}</span> : <span class="cylinder-status">In progress</span>}
                  </>
                );
                return isFinished ? (
                  <a
                    class="cylinder-item cylinder-item--finished"
                    data-cylinder-item
                    data-cylinder-status="finished"
                    data-cylinder-index={index}
                    href={item.href}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener noreferrer' : undefined}
                    draggable="false"
                    style={`--cylinder-angle: ${angle}deg; --cylinder-image: url('${item.image}'); --cylinder-mobile-image: url('${item.mobileImage}');`}
                  >
                    {content}
                  </a>
                ) : (
                  <article
                    class="cylinder-item cylinder-item--in-progress"
                    data-cylinder-item
                    data-cylinder-status="in-progress"
                    data-cylinder-index={index}
                    aria-label={`${item.name}, in progress`}
                    style={`--cylinder-angle: ${angle}deg; --cylinder-image: url('${item.image}'); --cylinder-mobile-image: url('${item.mobileImage}');`}
                  >
                    {content}
                  </article>
                );
              })}
            </div>
          </div>
          <p class="carousel-centre-label">examples and templates</p>
        </div>
      </div>
    </section>

    <section id="service-faq" class="scope-note decision-note service-faq" aria-labelledby="service-faq-heading">
      <p class="eyebrow">Common questions</p>
      <h2 id="service-faq-heading">Questions before starting a website</h2>
      <div class="service-faq-list service-faq-list--dropdown" aria-label="Website-development frequently asked questions">
        {serviceFaq.map((item) => (
          <details class="service-faq-item" data-service-faq-item={item.question}>
            <summary data-faq-summary>
              <span>{item.question}</span>
              <span class="service-faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="service-faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section id="contact" class="scope-note decision-note" aria-labelledby="contact-heading">
      <p class="eyebrow">Direct inquiry</p>
      <h2 id="contact-heading">Contact information</h2>
      <p>For collaborations or inquiries, please use the contact information below or send me a message.</p>
      <div class="decision-grid" aria-label="Contact methods">
        <article>
          <strong>Email</strong>
          <span><a href="mailto:hello@lucakosowski.com">hello@lucakosowski.com</a></span>
        </article>

        <article>
          <strong>LinkedIn</strong>
          <span><a href="https://www.linkedin.com/in/luca-kosowski/" target="_blank" rel="noopener noreferrer">linkedin.com/in/luca-kosowski</a></span>
        </article>
      </div>
    </section>


  </main>

  <script is:inline>
    (() => {
      const lavaLayer = document.querySelector('[data-lava-lamp-bg]');
      const lavaCanvas = lavaLayer?.querySelector('[data-lava-canvas]');
      const lavaMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      const lavaMobileQuery = window.matchMedia('(max-width: 720px)');
      const randomBetween = (min, max) => min + Math.random() * (max - min);
      if (lavaCanvas) {
        const ctx = lavaCanvas.getContext('2d', { alpha: true });
        if (ctx) {
          let lavaWidth = 1;
          let lavaHeight = 1;
          let lavaStableMobileWidth = 0;
          let lavaStableMobileHeight = 0;
          let lastLavaFrame = 0;
          const LAVA_DESKTOP_FRAME_MS = 1000 / 22;
          const LAVA_MOBILE_FRAME_MS = 1000 / 8;
          const colors = [
            ['rgba(79,150,232,0.31)', 'rgba(79,150,232,0.07)'],
            ['rgba(191,156,255,0.30)', 'rgba(191,156,255,0.06)'],
            ['rgba(255,184,101,0.25)', 'rgba(255,184,101,0.055)'],
            ['rgba(95,195,226,0.22)', 'rgba(95,195,226,0.055)'],
            ['rgba(255,255,255,0.34)', 'rgba(255,255,255,0.08)'],
          ];
          const ease = (t) => t * t * (3 - 2 * t);
          const mix = (a, b, t) => a + (b - a) * t;
          const makePoint = () => {
            const maxSide = Math.max(lavaWidth, lavaHeight);
            return {
              x: randomBetween(-0.12 * lavaWidth, 1.12 * lavaWidth),
              y: randomBetween(-0.12 * lavaHeight, 1.12 * lavaHeight),
              r: randomBetween(0.22 * maxSide, 0.46 * maxSide),
              sx: randomBetween(0.72, 1.55),
              sy: randomBetween(0.62, 1.34),
              rotation: randomBetween(-Math.PI, Math.PI),
            };
          };
          const lavaDuration = () => lavaMobileQuery.matches ? randomBetween(22000, 42000) : randomBetween(1800, 3900);
          const blobs = colors.map((color, index) => ({
            color,
            start: makePoint(),
            current: makePoint(),
            target: makePoint(),
            startedAt: performance.now() - index * 260,
            duration: lavaDuration(),
          }));
          const retarget = (blob, now) => {
            blob.start = { ...blob.current };
            blob.target = makePoint();
            blob.startedAt = now;
            blob.duration = lavaDuration();
          };
          const resizeLava = () => {
            const viewportWidth = Math.max(1, window.innerWidth);
            const viewportHeight = Math.max(1, window.innerHeight);
            const isMobile = lavaMobileQuery.matches;
            let width = viewportWidth;
            let height = viewportHeight;

            if (isMobile) {
              const widthChanged = !lavaStableMobileWidth || Math.abs(viewportWidth - lavaStableMobileWidth) > 24;
              if (!widthChanged) return false;
              lavaStableMobileWidth = viewportWidth;
              lavaStableMobileHeight = Math.max(lavaStableMobileHeight, viewportHeight, window.screen?.height || 0);
              height = lavaStableMobileHeight;
              width = lavaStableMobileWidth;
            }

            const nextWidth = Math.round(Math.min(520, Math.max(240, width / 3.6)));
            const nextHeight = Math.round(nextWidth * (height / width));
            const changed = lavaCanvas.width !== nextWidth || lavaCanvas.height !== nextHeight;
            if (!changed) return false;
            lavaWidth = nextWidth;
            lavaHeight = nextHeight;
            lavaCanvas.width = lavaWidth;
            lavaCanvas.height = lavaHeight;
            return true;
          };
          const shouldAnimateLava = () => !lavaMotionQuery.matches && !lavaMobileQuery.matches && !document.hidden;
          const drawLava = (now, force = false) => {
            const frameMs = lavaMobileQuery.matches ? LAVA_MOBILE_FRAME_MS : LAVA_DESKTOP_FRAME_MS;
            if (!force && now - lastLavaFrame < frameMs) {
              if (shouldAnimateLava()) requestAnimationFrame(drawLava);
              return;
            }
            lastLavaFrame = now;
            ctx.clearRect(0, 0, lavaWidth, lavaHeight);
            blobs.forEach((blob) => {
              if (shouldAnimateLava() && now - blob.startedAt >= blob.duration) retarget(blob, now);
              const t = shouldAnimateLava() ? ease(Math.min(1, Math.max(0, (now - blob.startedAt) / blob.duration))) : 0.35;
              blob.current = {
                x: mix(blob.start.x, blob.target.x, t),
                y: mix(blob.start.y, blob.target.y, t),
                r: mix(blob.start.r, blob.target.r, t),
                sx: mix(blob.start.sx, blob.target.sx, t),
                sy: mix(blob.start.sy, blob.target.sy, t),
                rotation: mix(blob.start.rotation, blob.target.rotation, t),
              };
              const gradient = ctx.createRadialGradient(0, 0, 0, 0, 0, blob.current.r);
              gradient.addColorStop(0, blob.color[0]);
              gradient.addColorStop(0.55, blob.color[1]);
              gradient.addColorStop(1, 'rgba(255,255,255,0)');
              ctx.save();
              ctx.translate(blob.current.x, blob.current.y);
              ctx.rotate(blob.current.rotation);
              ctx.scale(blob.current.sx, blob.current.sy);
              ctx.fillStyle = gradient;
              ctx.beginPath();
              ctx.arc(0, 0, blob.current.r, 0, Math.PI * 2);
              ctx.fill();
              ctx.restore();
            });
            if (shouldAnimateLava()) requestAnimationFrame(drawLava);
          };
          const resetLavaBlobs = (now = performance.now()) => {
            blobs.forEach((blob) => {
              blob.start = makePoint();
              blob.current = { ...blob.start };
              blob.target = makePoint();
              blob.startedAt = now;
              blob.duration = lavaDuration();
            });
          };
          resizeLava();
          const initialLavaNow = performance.now();
          resetLavaBlobs(initialLavaNow);
          drawLava(initialLavaNow, true);
          window.addEventListener('resize', () => {
            if (!resizeLava()) return;
            const now = performance.now();
            resetLavaBlobs(now);
            drawLava(now, true);
          }, { passive: true });
          document.addEventListener('visibilitychange', () => {
            if (!document.hidden && !lavaMotionQuery.matches) requestAnimationFrame(drawLava);
          });
          lavaMotionQuery.addEventListener?.('change', () => drawLava(performance.now(), true));
          lavaMobileQuery.addEventListener?.('change', () => drawLava(performance.now(), true));
          if (shouldAnimateLava()) requestAnimationFrame(drawLava);
        }
      }

      const header = document.querySelector('[data-materialized-header]');
      const hero = document.querySelector('.hero--trsnparent_wheel');
      if (header && hero) {
        const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        const REVEAL_WINDOW = 120;
        const INERT_THRESHOLD = 0.5;
        let ticking = false;
        const applyProgress = (progress) => {
          header.style.setProperty('--header-progress', String(progress));
          header.toggleAttribute('inert', progress < INERT_THRESHOLD);
        };
        const update = () => {
          ticking = false;
          const heroBottom = hero.getBoundingClientRect().bottom;
          if (reduceMotionQuery.matches) {
            applyProgress(heroBottom <= 0 ? 1 : 0);
            return;
          }
          const raw = (REVEAL_WINDOW - heroBottom) / REVEAL_WINDOW;
          applyProgress(Math.min(1, Math.max(0, raw)));
        };
        const onScroll = () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        };
        update();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        reduceMotionQuery.addEventListener?.('change', onScroll);
      }

      const stage = document.querySelector('[data-trsnparent-wheel]');
      const wrap = stage?.querySelector('[data-cylinder-wrap]');
      if (!stage || !wrap) return;

      const items = Array.from(wrap.querySelectorAll('[data-cylinder-item]'));
      const count = items.length;
      const theta = 360 / count;
      const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      const view = stage.querySelector('[data-cylinder-view]');
      const dragHint = stage.querySelector('[data-carousel-drag-hint]');
      const mobileCarouselQuery = window.matchMedia('(max-width: 720px)');
      const AUTOPLAY_DEGREES_PER_MS = 360 / (7 * 60 * 1000);
      const HOVER_IDLE_AUTOPLAY_DELAY_MS = 3500;
      const HOVER_MAGNET_MAX_STEP_DEGREES = 0.16;
      const HOVER_MAGNET_DEAD_ZONE_PX = 4;
      const HOVER_SIDE_LOCK_MAX_DISTANCE_PX = 2400;
      const HOVER_SIDE_LOCK_SWITCH_DISTANCE_PX = -1;
      const HOVER_CENTER_LOCK_MAX_DISTANCE_PX = 48;
      const HOVER_CENTER_LOCK_SWITCH_DISTANCE_PX = 260;
      const DRAG_DEGREES_PER_PX = 0.26;
      const MOBILE_DRAG_DEGREES_PER_PX = 0.28;
      const DRAG_CLICK_THRESHOLD_PX = 6;
      const TOUCH_HORIZONTAL_INTENT_PX = 3;
      const MOBILE_RELEASE_BASE_MULTIPLIER = 0.68;
      const MOBILE_RELEASE_FAST_BOOST = 0.42;
      const MOBILE_RELEASE_FAST_VELOCITY = 8;
      const MOBILE_RELEASE_LIMIT = 8.4;
      const MOBILE_INERTIA_DECAY = 0.968;
      const MANUAL_RESUME_DELAY_MS = 4200;
      const HINT_INITIAL_DELAY_MS = 1000;
      const HINT_REPEAT_DELAY_MS = 5000;
      const HINT_MAX_SHOWS = 3;
      const PREVIEW_REVEAL_DELAY_MS = 2500;

      let currentAngle = 0;
      let targetAngle = 0;
      let radius = 0;
      let isDragging = false;
      let isHovering = false;
      let hoverPoint = null;
      let cursorVelocityX = 0;
      let lastHoverMotionTime = 0;
      let magnetAngularVelocity = 0;
      let magnetLockedIndex = -1;
      let startX = 0;
      let dragStartAngle = 0;
      let dragStartCenterX = 0;
      let dragGrabOffsetX = 0;
      let dragIntent = 'idle';
      let dragPointerId = 0;
      let startY = 0;
      let dragMoved = false;
      let stoppedMotionOnTouch = false;
      let lastDragX = 0;
      let lastDragTime = 0;
      let dragAngularVelocity = 0;
      let suppressClickUntil = 0;
      let manualHoldUntil = reduceMotionQuery.matches ? Number.POSITIVE_INFINITY : 0;
      let hintShows = 0;
      let hintTimer = 0;
      let lastFrame = performance.now();
      let lastActive = -1;
      let activeSince = performance.now();

      const normalizeIndex = () => {
        const rawIndex = Math.round((-currentAngle) / theta);
        return ((rawIndex % count) + count) % count;
      };

      const holdAutoplayBriefly = () => {
        manualHoldUntil = reduceMotionQuery.matches ? Number.POSITIVE_INFINITY : performance.now() + MANUAL_RESUME_DELAY_MS;
      };

      const updateFocusable = (activeIndex) => {
        items.forEach((item, index) => {
          const active = index === activeIndex;
          item.classList.toggle('is-active', active);
          if (!active) item.classList.remove('is-preview-ready');
          item.setAttribute('aria-current', active ? 'true' : 'false');
          if (item.matches('a')) item.tabIndex = active ? 0 : -1;
        });
      };

      const layout = () => {
        const cardWidth = (wrap.offsetWidth || Number.parseFloat(getComputedStyle(wrap).width) || wrap.getBoundingClientRect().width) + 42;
        const naturalRadius = Math.round((cardWidth / 2) / Math.tan(Math.PI / count));
        const mobileMinimumRadius = window.innerWidth < 720 ? 188 : 0;
        radius = Math.max(naturalRadius, mobileMinimumRadius);
        items.forEach((item, index) => {
          item.style.transform = `rotateY(${index * theta}deg) translateZ(${radius}px)`;
        });
      };

      const snap = () => {
        const snapIndex = Math.round(targetAngle / theta);
        targetAngle = snapIndex * theta;
      };

      const rotateBy = (direction) => {
        holdAutoplayBriefly();
        targetAngle += direction * theta;
        snap();
      };

      const showDragHint = () => {
        hintTimer = 0;
        if (!dragHint || hintShows >= HINT_MAX_SHOWS) return;
        hintShows += 1;
        dragHint.classList.add('is-visible');
      };

      const scheduleDragHint = (delay) => {
        if (!dragHint || hintShows >= HINT_MAX_SHOWS || hintTimer) return;
        hintTimer = window.setTimeout(showDragHint, delay);
      };

      const hideDragHint = () => {
        const wasVisible = dragHint?.classList.contains('is-visible');
        if (wasVisible) {
          dragHint?.classList.remove('is-visible');
          scheduleDragHint(HINT_REPEAT_DELAY_MS);
          return;
        }
        if (hintShows === 0 && hintTimer) {
          window.clearTimeout(hintTimer);
          hintTimer = 0;
          scheduleDragHint(HINT_REPEAT_DELAY_MS);
        }
      };

      scheduleDragHint(HINT_INITIAL_DELAY_MS);

      const updateHover = (event) => {
        if (event.type === 'pointermove') hideDragHint();
        const now = performance.now();
        const pointerMoved = !hoverPoint || Math.hypot(event.clientX - hoverPoint.x, event.clientY - hoverPoint.y) > 0.5;
        if (pointerMoved) lastHoverMotionTime = now;
        if (hoverPoint?.time) {
          const elapsed = Math.max(8, now - hoverPoint.time);
          const instantVelocity = (event.clientX - hoverPoint.x) / elapsed;
          cursorVelocityX = cursorVelocityX * 0.62 + instantVelocity * 0.38;
        }
        hoverPoint = { x: event.clientX, y: event.clientY, time: now };
      };

      const applyMagneticHover = (delta) => {
        if (!hoverPoint || !items.length) return false;

        let bestCandidate = null;
        let lockedCandidate = null;
        items.forEach((item, index) => {
          const totalAngle = ((((index * theta + currentAngle) % 360) + 540) % 360) - 180;
          const frontness = Math.cos(totalAngle * Math.PI / 180);
          if (frontness < -0.2) return;

          const rect = item.getBoundingClientRect();
          if (!rect.width || !rect.height) return;
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const horizontalDistance = Math.abs(hoverPoint.x - centerX);
          const verticalDistance = Math.abs(hoverPoint.y - centerY);
          const isSideTab = Math.abs(totalAngle) > 18;
          const cursorInsideCardX = hoverPoint.x >= rect.left && hoverPoint.x <= rect.right;
          const centerShoulderPenalty = isSideTab ? 0 : Math.max(0, horizontalDistance - rect.width * 0.18) * 1.9;
          const sideCatchBonus = isSideTab && cursorInsideCardX ? rect.width * 0.24 : 0;
          const distance = horizontalDistance + verticalDistance * 0.18 + centerShoulderPenalty - sideCatchBonus;
          const candidate = { index, rect, distance, rotationSign: Math.sign(frontness) || 1, isSideTab };
          if (!bestCandidate || distance < bestCandidate.distance) bestCandidate = candidate;
          if (index === magnetLockedIndex) lockedCandidate = candidate;
        });

        const lockMaxDistance = lockedCandidate?.isSideTab ? HOVER_SIDE_LOCK_MAX_DISTANCE_PX : HOVER_CENTER_LOCK_MAX_DISTANCE_PX;
        const lockSwitchDistance = lockedCandidate?.isSideTab ? HOVER_SIDE_LOCK_SWITCH_DISTANCE_PX : HOVER_CENTER_LOCK_SWITCH_DISTANCE_PX;
        const keepLocked = lockedCandidate && lockedCandidate.distance < lockMaxDistance && (!bestCandidate || bestCandidate.distance > lockSwitchDistance);
        const magnetCandidate = keepLocked ? lockedCandidate : bestCandidate;
        if (magnetCandidate) magnetLockedIndex = magnetCandidate.index;

        const fallbackItem = items[lastActive >= 0 ? lastActive : normalizeIndex()];
        const rect = magnetCandidate?.rect || fallbackItem?.getBoundingClientRect();
        const magnetRotationSign = magnetCandidate?.rotationSign || 1;
        if (!rect?.width || !rect?.height) return false;

        const cardCenterX = rect.left + rect.width / 2;
        const cardCenterY = rect.top + rect.height / 2;
        const dx = hoverPoint.x - cardCenterX;
        if (Math.abs(dx) < HOVER_MAGNET_DEAD_ZONE_PX) return true;

        const dy = hoverPoint.y - cardCenterY;
        const pullDirection = Math.sign(dx);
        const horizontalPull = Math.min(1, Math.abs(dx) / (rect.width * 0.62));
        const proximity = Math.max(0.22, Math.min(1.08, 1.22 - Math.hypot(dx / rect.width, dy / rect.height)));
        const stepScale = Math.min(2.4, delta / 16.67);
        const cursorSpeed = Math.min(1, Math.abs(cursorVelocityX) / 1.35);
        const magneticGrip = 1 - cursorSpeed * 0.48;
        const centerEdgeFade = magnetCandidate?.isSideTab ? 1 : Math.max(0.06, 1 - Math.pow(Math.min(1, Math.abs(dx) / (rect.width * 0.30)), 1.35));
        const sideCatchZone = magnetCandidate?.isSideTab && hoverPoint.x >= rect.left && hoverPoint.x <= rect.right;
        const sideOuterPosition = sideCatchZone ? Math.min(1, Math.abs(hoverPoint.x - cardCenterX) / (rect.width * 0.5)) : 0;
        const sidePullBoost = magnetCandidate?.isSideTab ? (sideCatchZone ? 0.52 + sideOuterPosition * 0.08 : 0.40) : 0.24 * centerEdgeFade;
        const attraction = pullDirection * magnetRotationSign * Math.pow(horizontalPull, 0.74) * proximity * HOVER_MAGNET_MAX_STEP_DEGREES * magneticGrip * sidePullBoost * stepScale;
        const fling = Math.sign(cursorVelocityX) * magnetRotationSign * Math.pow(cursorSpeed, 0.8) * (magnetCandidate?.isSideTab ? 0.04 : 0.015 * centerEdgeFade) * stepScale;
        magnetAngularVelocity = Math.max(-0.42, Math.min(0.42, magnetAngularVelocity + attraction * 0.05 + fling));
        targetAngle += attraction * 0.11 + magnetAngularVelocity;
        magnetAngularVelocity *= 0.84;
        return true;
      };

      const start = (event) => {
        if (event.button !== 0) return;
        const isTouchPointer = event.pointerType === 'touch';
        // Do not cancel desktop pointerdown: finished cards are anchors, and
        // cancelling pointerdown can suppress their default navigation.
        holdAutoplayBriefly();
        hideDragHint();
        const hadWheelMotion = Math.abs(magnetAngularVelocity) > 0.03 || Math.abs(targetAngle - currentAngle) > 0.25;
        isDragging = true;
        dragIntent = isTouchPointer ? 'pending' : 'horizontal';
        dragPointerId = event.pointerId;
        dragMoved = false;
        stoppedMotionOnTouch = isTouchPointer && hadWheelMotion;
        if (stoppedMotionOnTouch) suppressClickUntil = performance.now() + 420;
        magnetAngularVelocity = 0;
        magnetLockedIndex = -1;
        dragAngularVelocity = 0;
        targetAngle = currentAngle;
        wrap.style.transform = `rotateY(${currentAngle}deg)`;
        startX = event.clientX;
        startY = event.clientY;
        lastDragX = event.clientX;
        lastDragTime = performance.now();
        dragStartAngle = currentAngle;

        const grabbedItem = items.reduce((closest, item) => {
          const rect = item.getBoundingClientRect();
          if (!rect.width || !rect.height) return closest;
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const distance = Math.abs(event.clientX - centerX) + Math.abs(event.clientY - centerY) * 0.18;
          return !closest || distance < closest.distance ? { item, rect, centerX, distance } : closest;
        }, null);
        dragStartCenterX = grabbedItem?.centerX || event.clientX;
        dragGrabOffsetX = event.clientX - dragStartCenterX;

        if (!isTouchPointer) {
          // Keep simple clicks on finished preview anchors targetable; window-level
          // move/up listeners already maintain desktop drag tracking without capture.
          view?.classList.add('is-dragging');
        }
      };

      const move = (event) => {
        if (!isDragging) {
          updateHover(event);
          return;
        }
        const deltaX = event.clientX - startX;
        if (event.pointerType === 'touch') {
          const deltaY = event.clientY - startY;
          if (dragIntent === 'pending') {
            const absX = Math.abs(deltaX);
            const absY = Math.abs(deltaY);
            if (absY > DRAG_CLICK_THRESHOLD_PX && absY > absX) {
              dragMoved = true;
              end(event);
              return;
            }
            if (absX <= TOUCH_HORIZONTAL_INTENT_PX || absX <= absY) return;
            dragIntent = 'horizontal';
            view?.setPointerCapture?.(event.pointerId);
            view?.classList.add('is-dragging');
          }
          if (dragIntent !== 'horizontal') return;
          event.preventDefault();
        } else {
          event.preventDefault();
        }
        const now = performance.now();
        const dragDistance = deltaX;
        const elapsed = Math.max(8, now - lastDragTime);
        const crossedDragThreshold = Math.abs(dragDistance) > DRAG_CLICK_THRESHOLD_PX;
        if (!dragMoved && crossedDragThreshold && event.pointerType !== 'touch') {
          view?.setPointerCapture?.(event.pointerId);
        }
        dragMoved = dragMoved || crossedDragThreshold;
        const dragDegreesPerPx = window.innerWidth < 720 ? MOBILE_DRAG_DEGREES_PER_PX : DRAG_DEGREES_PER_PX;
        dragAngularVelocity = ((event.clientX - lastDragX) * dragDegreesPerPx / elapsed) * 16.67;
        const grabbedTargetX = event.clientX - dragGrabOffsetX;
        targetAngle = dragStartAngle + (grabbedTargetX - dragStartCenterX) * dragDegreesPerPx;
        currentAngle = targetAngle;
        wrap.style.transform = `rotateY(${currentAngle}deg)`;
        lastDragX = event.clientX;
        lastDragTime = now;
      };

      const end = (event) => {
        if (!isDragging) return;
        isDragging = false;
        dragIntent = 'idle';
        dragPointerId = 0;
        if (view?.hasPointerCapture?.(event.pointerId)) view.releasePointerCapture(event.pointerId);
        view?.classList.remove('is-dragging');
        if (dragMoved || stoppedMotionOnTouch) suppressClickUntil = performance.now() + 350;
        stoppedMotionOnTouch = false;
        const mobileRelease = window.innerWidth < 720;
        const releaseMultiplier = mobileRelease
          ? MOBILE_RELEASE_BASE_MULTIPLIER + Math.min(MOBILE_RELEASE_FAST_BOOST, Math.abs(dragAngularVelocity) / MOBILE_RELEASE_FAST_VELOCITY * MOBILE_RELEASE_FAST_BOOST)
          : 0.72;
        const releaseLimit = mobileRelease ? MOBILE_RELEASE_LIMIT : 5.2;
        magnetAngularVelocity = Math.max(-releaseLimit, Math.min(releaseLimit, dragAngularVelocity * releaseMultiplier));
      };

      view?.addEventListener('pointerenter', (event) => {
        isHovering = true;
        updateHover(event);
      });
      view?.addEventListener('pointerleave', () => {
        isHovering = false;
        hoverPoint = null;
        cursorVelocityX = 0;
        magnetLockedIndex = -1;
      });
      view?.addEventListener('pointerdown', start);
      window.addEventListener('pointermove', move);
      window.addEventListener('pointerup', end);
      window.addEventListener('pointercancel', end);
      stage.addEventListener('click', (event) => {
        if (performance.now() < suppressClickUntil) {
          event.preventDefault();
          event.stopPropagation();
        }
      }, true);
      stage.addEventListener('dragstart', (event) => {
        event.preventDefault();
      }, true);
      stage.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          rotateBy(1);
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          rotateBy(-1);
        }
      });
      reduceMotionQuery.addEventListener?.('change', () => {
        manualHoldUntil = reduceMotionQuery.matches ? Number.POSITIVE_INFINITY : 0;
      });
      mobileCarouselQuery.addEventListener?.('change', () => {
        if (mobileCarouselQuery.matches) holdAutoplayBriefly();
      });

      const animate = (now) => {
        const delta = Math.min(80, now - lastFrame);
        lastFrame = now;
        const hoverIdle = isHovering && !isDragging && (now - lastHoverMotionTime) >= HOVER_IDLE_AUTOPLAY_DELAY_MS;
        if (hoverIdle) magnetLockedIndex = -1;
        const hoverActive = isHovering && !hoverIdle && !isDragging && applyMagneticHover(delta);
        const stepScale = Math.min(2.4, delta / 16.67);
        const inertiaActive = !isDragging && !hoverActive && Math.abs(magnetAngularVelocity) > 0.015;
        if (inertiaActive) {
          targetAngle += magnetAngularVelocity * stepScale;
          magnetAngularVelocity *= window.innerWidth < 720 ? MOBILE_INERTIA_DECAY : 0.94;
        }
        const autoplayAllowed = !mobileCarouselQuery.matches && !reduceMotionQuery.matches && !isDragging && !hoverActive && !inertiaActive && now >= manualHoldUntil;
        if (autoplayAllowed) {
          targetAngle -= delta * AUTOPLAY_DEGREES_PER_MS;
        }
        const nextAngle = currentAngle + (targetAngle - currentAngle) * 0.08;
        if (Math.abs(nextAngle - currentAngle) > 0.002) {
          currentAngle = nextAngle;
          wrap.style.transform = `rotateY(${currentAngle}deg)`;
        } else {
          currentAngle = targetAngle;
        }
        const active = normalizeIndex();
        if (active !== lastActive) {
          updateFocusable(active);
          lastActive = active;
          activeSince = now;
        } else if (now - activeSince >= PREVIEW_REVEAL_DELAY_MS) {
          items[active]?.classList.add('is-preview-ready');
        }
        requestAnimationFrame(animate);
      };

      layout();
      updateFocusable(0);
      window.addEventListener('resize', layout, { passive: true });
      requestAnimationFrame(animate);
    })();
  </script>

</ServiceLayout>
