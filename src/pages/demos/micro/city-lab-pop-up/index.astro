<body id="top" data-package-tier="micro" data-design-signature="event-poster-system" data-design-archetype="micro-event-poster">
  <a class="wd-back-link" href="/#demos" aria-label="Back to Website Development">← Back to Website Development</a>
  <header class="city-header">
    <a class="city-brand" href="#top">City Lab Pop-Up</a>
    <nav aria-label="City Lab sections">
      <a href="#schedule">Schedule</a>
      <a href="#arrival">Arrival</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <section class="poster-grid" aria-labelledby="city-title">
      <div class="poster-type">
        <p class="poster-kicker">Fictional demo · Micro event page</p>
        <h1 id="city-title"><span>Saturday ideas, </span><span>loud enough </span><span>for the whole block.</span></h1>
        <div class="poster-meta" aria-label="Event highlights"><span>open tables</span><span>mini talks</span><span>workshop notes</span></div>
      </div>
      <aside class="ticket-stub" aria-label="Event ticket details">
        <span>one afternoon</span>
        <strong>12:00–5:00</strong>
        <p>Corner lot, three tents, local makers, food cart, and a zine table.</p>
      </aside>
    </section>

    <section class="schedule-marquee" id="schedule" aria-labelledby="schedule-title">
      <p>Schedule</p>
      <h2 id="schedule-title">A simple day plan, readable from the sidewalk.</h2>
      <ol>
        <li><span>12:00</span> Doors, coffee, maker tables</li>
        <li><span>13:30</span> Tiny talks under the blue tent</li>
        <li><span>15:00</span> Neighborhood mapping workshop</li>
        <li><span>16:30</span> Open mic and wrap notes</li>
      </ol>
    </section>

    <section class="neon-map" aria-labelledby="map-title">
      <p class="poster-kicker">Where it happens</p>
      <h2 id="map-title">Three blocks, one bright corner.</h2>
      <div class="map-card"><span>north gate</span><span>food cart</span><span>zine table</span><span>blue tent</span></div>
    </section>

    <section class="lab-cards" aria-labelledby="cards-title">
      <p class="poster-kicker">Pop-up pieces</p>
      <h2 id="cards-title">Every block has a job.</h2>
      <div class="card-grid">
        <article><h3>Open tables</h3><p>Local projects show what they need and what neighbors can help with.</p></article>
        <article><h3>Mini talks</h3><p>Ten-minute talks with a hard stop and a public notes wall.</p></article>
        <article><h3>Workshop notes</h3><p>Printed prompts make the event useful after Saturday.</p></article>
      </div>
    </section>

    <section class="arrival-strip" id="arrival" aria-labelledby="arrival-title">
      <h2 id="arrival-title">Arrive without guessing.</h2>
      <ul>
        <li>Bike rack on Maple</li><li>Rain plan under the awning</li><li>Text-only updates by phone</li>
      </ul>
    </section>

    <section class="micro-boundary" aria-labelledby="boundary-title">
      <p class="poster-kicker">Micro scope</p>
      <h2 id="boundary-title">Static, loud, and honest.</h2>
      <p>This fictional demo is a one-page event teaser with direct links, robots.txt, favicon, and no form. It does not include registration, ticketing, payment, CMS editing, or analytics.</p>
    </section>

    <section class="city-close" id="contact" aria-labelledby="contact-title">
      <p class="poster-kicker">Contact</p>
      <h2 id="contact-title">Ask about a table spot.</h2>
      <a class="city-button" href="mailto:popup@example.test">popup@example.test</a>
    </section>
  </main>

  <footer>
    <p>Fictional demo for Website Development package examples. Static Micro page.</p>
    <a href="#top">Back to top</a>
    <a class="footer-back-to-web-development" href="/#demos">← Back to Website Development</a>
  </footer>
  <script data-goatcounter="https://websites.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</body>
</html>
