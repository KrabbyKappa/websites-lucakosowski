---
import SeoJsonLd from '../components/SeoJsonLd.astro';
import { seoSite } from '../data/seo/site';
import type { AnswerCluster } from '../data/seo/answerClusters';
import { canonicalUrl } from '../lib/seo/url';
import { answerClusterSchema } from '../lib/seo/schema';
import { siblingAnswerLinks } from '../lib/seo/internalLinks';

interface Props {
  cluster: AnswerCluster;
}

const { cluster } = Astro.props;
const canonical = canonicalUrl(cluster.url);
const schema = answerClusterSchema(cluster);
const siblings = siblingAnswerLinks(cluster.id);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{cluster.title} – Luca Kosowski Answers</title>
  <meta name="description" content={cluster.summary}>
  <link rel="canonical" href={canonical}>
  <meta property="og:title" content={`${cluster.title} – Luca Kosowski Answers`}>
  <meta property="og:description" content={cluster.summary}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={canonical}>
  <meta property="og:site_name" content={seoSite.name}>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={`${cluster.title} – Luca Kosowski Answers`}>
  <meta name="twitter:description" content={cluster.summary}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <SeoJsonLd data={schema} /><style>
    :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f7f4ef; color: #1d1b18; }
    body { margin: 0; background: radial-gradient(circle at top left, rgba(222, 166, 84, 0.16), transparent 28rem), #f7f4ef; }
    a { color: #8f4f18; }
    .answer-shell { max-width: 920px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
    .answer-top { display: flex; justify-content: space-between; gap: 1rem; align-items: center; margin-bottom: 2rem; font-size: 0.95rem; }
    .answer-top a { text-decoration: none; font-weight: 700; }
    .answer-card { background: rgba(255,255,255,0.86); border: 1px solid rgba(71,55,35,0.16); border-radius: 28px; box-shadow: 0 24px 70px rgba(71,55,35,0.10); padding: clamp(1.35rem, 4vw, 3rem); }
    .eyebrow { margin: 0 0 0.75rem; text-transform: uppercase; letter-spacing: .11em; color: #9a6b36; font-size: .78rem; font-weight: 800; }
    h1 { margin: 0; font-size: clamp(2rem, 5vw, 3.55rem); line-height: 0.97; letter-spacing: -.04em; }
    .summary { font-size: 1.12rem; line-height: 1.75; color: #50483f; margin: 1.4rem 0 0; max-width: 72ch; }
    .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: .75rem; margin: 2rem 0; }
    .meta-grid div { border: 1px solid rgba(71,55,35,.13); border-radius: 18px; padding: .9rem; background: rgba(247,244,239,.62); }
    .meta-grid strong { display: block; margin-bottom: .25rem; font-size: .8rem; text-transform: uppercase; color: #8f4f18; letter-spacing: .08em; }
    .qa-list { display: grid; gap: 1rem; margin-top: 2rem; }
    .qa-item { border-top: 1px solid rgba(71,55,35,.16); padding-top: 1.15rem; }
    .qa-item h2 { font-size: 1.18rem; line-height: 1.35; margin: 0 0 .55rem; }
    .qa-item p { margin: 0; color: #51483e; line-height: 1.72; }
    .sources, .related { margin-top: 2rem; padding-top: 1.25rem; border-top: 1px solid rgba(71,55,35,.16); color: #5c5246; }
    .sources ul, .related ul { margin: .75rem 0 0; padding-left: 1.25rem; }
    .footer-note { margin-top: 2rem; font-size: .92rem; color: #6f665b; }
  </style>
</head>
<body>
  <main class="answer-shell">
    <nav class="answer-top" aria-label="Answer support navigation">
      <a href="/">Luca Kosowski</a>
      <a href={cluster.supportPath}>Canonical support page</a>
    </nav>
    <article class="answer-card" data-answer-cluster={cluster.id} data-answer-family={cluster.family}>
      <p class="eyebrow">Question and answer documentation</p>
      <h1>{cluster.title}</h1>
      <p class="summary">{cluster.summary}</p>
      <div class="meta-grid" aria-label="Answer source metadata">
        <div><strong>Family</strong><span>{cluster.family === 'service' ? 'Website-development service' : 'Luca entity hub'}</span></div>
        <div><strong>Last reviewed</strong><span>{cluster.lastReviewed}</span></div>
        <div><strong>Support route</strong><a href={cluster.supportPath}>{cluster.supportPath}</a></div>
        <div><strong>Claim IDs</strong><span>{cluster.claimIds.join(', ')}</span></div>
      </div>
      <section class="qa-list" aria-label="Visible question and answer list">
        {cluster.questions.map((item) => (
          <section class="qa-item" data-answer-question={item.id}>
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
          </section>
        ))}
      </section>
      <section class="sources" aria-labelledby="source-map-heading">
        <h2 id="source-map-heading">Source map</h2>
        <ul>
          {cluster.sourceRefs.map((source) => <li>{source}</li>)}
        </ul>
      </section>
      {siblings.length > 0 && (
        <section class="related" aria-labelledby="related-answer-heading">
          <h2 id="related-answer-heading">Related answer pages</h2>
          <ul>
            {siblings.map((link) => <li><a href={link.url}>{link.title}</a></li>)}
          </ul>
        </section>
      )}
      <p class="footer-note">This page is intentionally readable and indexable, but it is not part of the main site navigation. It exists to help search and answer systems quote the portfolio accurately without inventing claims.</p>
    </article>
  </main>
  <script data-goatcounter="https://websites.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</body>
</html>
